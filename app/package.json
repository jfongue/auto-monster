{
  "name": "auto-battler-app",
  "private": true,
  "version": "0.1.0",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "install:all": "npm install --prefix server && npm install --prefix client",
    "seed": "npm run seed --prefix server",
    "dev:server": "npm run dev --prefix server",
    "dev:client": "npm run dev --prefix client",
    "dev": "concurrently -n server,client -c blue,green \"npm:dev:server\" \"npm:dev:client\"",
    "build": "npm run install:all && npm run build --prefix client",
    "start": "npm run start --prefix server",
    "screenshot": "node screenshot.mjs"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "playwright": "^1.49.0"
  }
}
